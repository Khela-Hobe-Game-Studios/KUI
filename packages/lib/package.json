{
  "name": "@khelahobe/kui",
  "version": "0.2.0",
  "description": "Khelahobe UI — cartoon-pastel component library for games",
  "type": "module",
  "main":   "./dist/index.cjs",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cpdb": {
      "types":   "./dist/cpdb.d.ts",
      "import":  "./dist/cpdb.js",
      "require": "./dist/cpdb.cjs"
    },
    "./fixedprice": {
      "types":   "./dist/fixedprice.d.ts",
      "import":  "./dist/fixedprice.js",
      "require": "./dist/fixedprice.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev":   "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "react":     "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react":        "^19.0.0",
    "@types/react-dom":    "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react":               "^19.0.0",
    "react-dom":           "^19.0.0",
    "sass":                "^1.77.0",
    "typescript":          "^5.5.0",
    "vite":                "^7.0.0",
    "vite-plugin-dts":     "^4.0.0"
  }
}
