{
  "compilerOptions": {
    "target":            "ES2020",
    "lib":               ["ES2020", "DOM", "DOM.Iterable"],
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "jsx":               "react-jsx",
    "strict":            true,
    "declaration":       true,
    "declarationDir":    "dist",
    "outDir":            "dist",
    "skipLibCheck":      true,
    "baseUrl":           ".",
    "paths": {
      "@kui/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
